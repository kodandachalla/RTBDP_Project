      "targets": [
        {
          "datasource": {
            "type": "postgres",
            "uid": "crypto_pg"
          },
          "editorMode": "code",
          "format": "time_series",
          "rawQuery": true,
          "rawSql": "SELECT\n  window_start AS \"time\",\n  trade_volume AS \"Volume\"\nFROM ohlc_candles\nWHERE symbol     = '$symbol'\n  AND window_size  = '$candle_size'\n  AND window_start >= $__timeFrom()\n  AND window_start <= $__timeTo()\nORDER BY window_start ASC;\n",
          "refId": "A",
          "sql": {
            "columns": [
              {
                "parameters": [],
                "type": "function"
              }
            ],
            "groupBy": [
              {
